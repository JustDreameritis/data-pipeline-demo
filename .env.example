# ============================================================
# Data Pipeline Toolkit — environment configuration
# Copy this file to .env and fill in your values
# ============================================================

# ----------------------------
# Data Sources
# ----------------------------

# HackerNews: how many stories to fetch, and which feed
HACKERNEWS_LIMIT=100
HACKERNEWS_FEED=topstories        # topstories | newstories | beststories

# GitHub trending: language and time window
GITHUB_LANGUAGE=python            # python | javascript | rust | any
GITHUB_TIMEFRAME=weekly           # daily | weekly | monthly
GITHUB_LIMIT=50
# Optional: set a GitHub token to raise API rate limit from 10 to 30 req/min
# GITHUB_TOKEN=ghp_...

# Weather: cities to fetch (comma-separated), forecast/history window
WEATHER_CITIES=London,New York,Tokyo,Sydney
WEATHER_FORECAST_DAYS=3
WEATHER_HISTORY_DAYS=0

# ----------------------------
# Processing
# ----------------------------

# How to handle missing values: drop | fill | flag
MISSING_VALUE_STRATEGY=flag

# Fuzzy deduplication similarity threshold (0.0–1.0)
# 0.85 = records must be 85% similar to be considered duplicates
DEDUP_SIMILARITY_THRESHOLD=0.85

# Fill values used when MISSING_VALUE_STRATEGY=fill
FILL_VALUE_STR=
FILL_VALUE_NUM=0.0

# ----------------------------
# Export
# ----------------------------

EXPORT_DIR=./output
SQLITE_DB_PATH=./output/pipeline.db
CSV_DELIMITER=,
CSV_APPEND=false

# Google Sheets (optional — see exporters/sheets_exporter.py for setup)
# GOOGLE_CREDENTIALS_PATH=/path/to/service-account-key.json
# GOOGLE_SPREADSHEET_ID=your-spreadsheet-id

# ----------------------------
# General
# ----------------------------

LOG_LEVEL=INFO          # DEBUG | INFO | WARNING | ERROR
REQUEST_DELAY=0.5       # Seconds between API calls
MAX_RETRIES=3           # Retry count for failed requests
